{
  "name": "memry",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "npx @electron/rebuild -f -o better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "npx @electron/rebuild -f -o better-sqlite3",
    "pretest": "npm run rebuild:node",
    "pretest:watch": "npm run rebuild:node",
    "pretest:ui": "npm run rebuild:node",
    "pretest:coverage": "npm run rebuild:node",
    "predev": "npm run rebuild:electron",
    "prebuild": "npm run rebuild:electron",
    "db:generate": "drizzle-kit generate --config drizzle-data.config.ts && drizzle-kit generate --config drizzle-index.config.ts",
    "db:generate:data": "drizzle-kit generate --config drizzle-data.config.ts",
    "db:generate:index": "drizzle-kit generate --config drizzle-index.config.ts",
    "db:push": "drizzle-kit push --config drizzle-data.config.ts && drizzle-kit push --config drizzle-index.config.ts",
    "db:push:data": "drizzle-kit push --config drizzle-data.config.ts",
    "db:push:index": "drizzle-kit push --config drizzle-index.config.ts",
    "db:studio:data": "drizzle-kit studio --config drizzle-data.config.ts",
    "db:studio:index": "drizzle-kit studio --config drizzle-index.config.ts",
    "db:seed": "npm run rebuild:node && npx tsx scripts/seed-tasks.ts",
    "db:seed:inbox": "npm run rebuild:node && npx tsx scripts/seed-inbox.ts",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:shared": "vitest run --project shared",
    "test:main": "vitest run --project main",
    "test:renderer": "vitest run --project renderer",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:component": "vitest run tests/component",
    "test:e2e": "playwright test",
    "sync:contracts": "bash scripts/sync-contracts.sh",
    "check:contracts": "bash scripts/check-contracts.sh"
  },
