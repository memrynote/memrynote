{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "../../packages/contracts/src/**/*",
    "../../packages/db-schema/src/**/*",
    "../../packages/shared/src/**/*"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@memry/contracts": [
        "../../packages/contracts/src/index.ts"
      ],
      "@memry/contracts/*": [
        "../../packages/contracts/src/*"
      ],
      "@memry/db-schema": [
        "../../packages/db-schema/src/index.ts"
      ],
      "@memry/db-schema/*": [
        "../../packages/db-schema/src/*"
      ],
      "@memry/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@memry/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@renderer/*": [
        "./src/renderer/src/*"
      ],
      "@/*": [
        "./src/renderer/src/*"
      ],
      "@tests/*": [
        "./tests/*"
      ]
    }
  }
}
