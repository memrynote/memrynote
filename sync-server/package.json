{
  "name": "memry-sync-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "cd .. && pnpm check:contracts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cborg": "^4.5.8",
    "hono": "^4.7.0",
    "jose": "^6.1.3",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250204.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0",
    "wrangler": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "rollup": ">=4.59.0"
    }
  }
}
